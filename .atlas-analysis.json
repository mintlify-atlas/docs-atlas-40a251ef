  "keyFeatures": [
    "AVL self-balancing binary search tree with insert, delete, search, and rotation operations",
    "Three traversal orders: inorder, preorder, and posorder",
    "Real-time obstacle updates via Socket.IO namespace /AVLTree",
    "REST API for node management and configuration loading",
    "Obstacle types with configurable damage values (cone, rock, tree, tire, nail, trunk, person, car, bicycle, chair)",
    "JSON configuration endpoint for bulk obstacle import with validation",
    "CORS-enabled Flask server running on localhost:4500"
  ],
  "publicApiSurface": [
    "GET /",
    "GET /avl",
    "POST /avl/node/add",
    "POST /avl/node/remove",
    "POST /avl/add/configs",
    "GET /data",
    "GET /data/json/<filename>",
    "Socket event: connect (namespace /AVLTree)",
    "Socket event: disconnect (namespace /AVLTree)",
    "Socket event: get_tree_avl → emits avl_tree_balanced",
    "Socket event: reset_avl → emits avl_reseted",
    "Socket event: remove_obstacle → emits avl_tree_balanced",
    "Socket event: road_preorder → emits preorder",
    "Socket event: road_inorder → emits inorder",
    "Socket event: road_posorder → emits posorder",
    "AVLTree.insert(obstacle: Obstacle) -> ReturnModels",
    "AVLTree.delete(obstacle: Obstacle) -> ReturnModels",
    "AVLTree.search(obstacle: Obstacle) -> ReturnModels",
    "AVLTree.inorder() -> ReturnModels",
    "AVLTree.preorder() -> ReturnModels",
    "AVLTree.posorder() -> ReturnModels",
    "AVLTree.to_dict() -> dict",
    "AVLTree.reset() -> None"
  ]
}
